{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviews"],
  "properties": {
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signalId",
          "status",
          "accuracyScore",
          "outboundUsefulnessScore",
          "rationale",
          "corrected",
          "prospectWebsetSuggestion",
          "issues"
        ],
        "properties": {
          "signalId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["approved", "needs_review", "rejected"]
          },
          "accuracyScore": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "outboundUsefulnessScore": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "rationale": { "type": "string" },
          "corrected": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "accountName",
              "companyDomain",
              "lane",
              "signalType",
              "confidence",
              "sourceQuality",
              "fsiSubsector",
              "workflow"
            ],
            "properties": {
              "accountName": { "type": ["string", "null"] },
              "companyDomain": { "type": ["string", "null"] },
              "lane": {
                "type": ["string", "null"],
                "enum": [
                  "official_ai_agent_launches",
                  "customer_ai_assistants",
                  "ai_leadership_team",
                  "job_posts_hiring",
                  "webinars_whitepapers",
                  "conference_speaker",
                  "governance_model_risk",
                  "vendor_partner_announcements",
                  "procurement_rfp",
                  "partner_marketplace",
                  "unknown",
                  null
                ]
              },
              "signalType": { "type": ["string", "null"] },
              "confidence": {
                "type": ["string", "null"],
                "enum": ["high", "medium", "low", null]
              },
              "sourceQuality": {
                "type": ["string", "null"],
                "enum": ["official", "trusted", "medium", "low", "unknown", null]
              },
              "fsiSubsector": { "type": ["string", "null"] },
              "workflow": { "type": ["string", "null"] }
            }
          },
          "prospectWebsetSuggestion": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": [
              "fitScore",
              "workflow",
              "title",
              "audience",
              "monitorQuery",
              "monitorCriteria",
              "valueProposition",
              "rationale"
            ],
            "properties": {
              "fitScore": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "workflow": { "type": "string" },
              "title": { "type": "string" },
              "audience": { "type": "string" },
              "monitorQuery": {
                "type": "string",
                "description": "Natural-language semantic search instruction for Exa Websets. Do not use site: filters, boolean operators, quoted keyword lists, or raw keyword bundles."
              },
              "monitorCriteria": {
                "type": "array",
                "minItems": 1,
                "maxItems": 5,
                "items": { "type": "string" }
              },
              "valueProposition": { "type": "string" },
              "rationale": { "type": "string" }
            }
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field", "severity", "message"],
              "properties": {
                "field": { "type": "string" },
                "severity": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
