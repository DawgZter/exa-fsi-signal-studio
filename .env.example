# Required for live Exa/Websets sync.
EXA_API_KEY=
EXA_WEBSET_ID=

# Optional. Exa Websets API base defaults to https://api.exa.ai/websets/v0.
EXA_WEBSETS_BASE_URL=

# Optional. Exa Answer API base defaults to https://api.exa.ai.
# Used by the Exa-native row sanitizer and account-level prospect Webset suggestions.
EXA_ANSWER_BASE_URL=
EXA_ANSWER_REVIEW_BATCH_SIZE=1
ACCOUNT_SUGGESTION_CRON_LIMIT=12
ACCOUNT_SUGGESTIONS_ON_SYNC=true

# Optional. Protect POST /api/sync in deployed environments.
SYNC_SECRET=

# Optional in local development, required in production for hosted UI requests
# that should provision new live prospect Websets. Choose any strong app
# passcode; this is not your Exa API key.
STUDIO_ADMIN_SECRET=

# Optional. Protects hosted account suggestion refresh/backfill routes. Falls
# back to SYNC_SECRET, CRON_SECRET, then STUDIO_ADMIN_SECRET when unset.
ACCOUNT_SUGGESTION_SECRET=

# Required for Vercel Cron in deployed environments. Vercel sends this as
# Authorization: Bearer $CRON_SECRET when invoking /api/cron/sync.
CRON_SECRET=

# Optional. Defaults to .local/fsi-signal-studio.
SIGNAL_STORE_PATH=

# Optional. If BLOB_READ_WRITE_TOKEN is present and DATA_STORE_BACKEND is not "file",
# synced JSON state can be persisted through Vercel Blob. Use Blob for deploys;
# local file storage is not durable serverless storage.
BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS=private
DATA_STORE_BACKEND=file
STORE_PREFIX=fsi-signal-studio

# Used when API responses construct generated prospect URLs.
APP_BASE_URL=http://localhost:3000

# Logo provider for prospect pages: clearbit, favicon, or none.
LOGO_PROVIDER=favicon
